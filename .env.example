# ==============================================================================
# ProofNode Environment Configuration (Example)
# Copy this file to .env and configure the actual values before running.
# ==============================================================================

# PostgreSQL / TimescaleDB
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgrespassword
POSTGRES_DB=proofnode
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Telegram Bot
# Get a token from @BotFather in Telegram
BOT_TOKEN=your_real_bot_token_here
# ID of the VIP channel/chat managed by the bot (must start with -100 for channels)
CHANNEL_ID=-10012345678

# KMS & Proxy Wallet Security
# KMS Provider: 'local', 'aws', or 'vault'
KMS_PROVIDER=local
# For 'local' provider, generate a 32-byte url-safe base64 key using:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
KMS_MASTER_KEY=wIMBmmGb3MDxPWKzYW71fTQx1lV52J2iEgGk9LW5HJI=

# Blockchain Webhook Secrets (signatures verified by backend gateway)
WEBHOOK_SECRET_TON=test_ton_secret
WEBHOOK_SECRET_SOL=test_sol_secret
WEBHOOK_SECRET_EVM=test_evm_secret
ALCHEMY_WEBHOOK_SECRET=alchemy_test_secret
HELIUS_WEBHOOK_SECRET=helius_test_secret
TONAPI_WEBHOOK_SECRET=tonapi_test_secret

# RPC URLs (used to verify swap transactions and fetch prices)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
BASE_RPC_URL=https://mainnet.base.org
TON_RPC_URL=https://toncenter.com/api/v2/jsonRPC

# Platform Parameters
PLATFORM_TREASURY_ADDRESS=EQ_PLATFORM_TREASURY_ADDRESS
PREMIUM_PRICE_TON=2.5
PREMIUM_PRICE_STARS=800

# Environment Mode (development / production / testing)
ENV=development
